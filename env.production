# Production Environment Configuration for HTTPS Internal Domain
# Copy this to .env.local for production use

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/automation_firm_db"

# NextAuth Configuration for HTTPS Internal Domain
NEXTAUTH_URL="https://192.168.10.95:3000"
NEXTAUTH_SECRET="your-generated-secret-here"

# Microsoft 365 Authentication (Azure AD)
MICROSOFT_CLIENT_ID="your-azure-ad-app-client-id"
MICROSOFT_CLIENT_SECRET="your-azure-ad-app-client-secret"
MICROSOFT_TENANT_ID="your-tenant-id"

# Email (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760" # 10MB

# External Integrations (for future use)
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""

# AI Services
OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
