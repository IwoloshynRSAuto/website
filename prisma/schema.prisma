generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                   @id @default(cuid())
  email                    String                   @unique
  name                     String?
  role                     String                   @default("USER")
  isActive                 Boolean                  @default(true)
  position                 String?
  wage                     Decimal?
  phone                    String?
  managerId                String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  manager                  User?                    @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports            User[]                   @relation("EmployeeManager")
  auditLogs                AuditLog[]               @relation("AuditLogs")
  ecoOrders                EngineeringChangeOrder[]
  createdJobs              Job[]                    @relation("JobCreator")
  assignedJobs             Job[]                    @relation("JobAssignee")
  timeEntries              TimeEntry[]
  rejectedTimesheets       TimesheetSubmission[]    @relation("TimesheetRejections")
  approvedTimesheets       TimesheetSubmission[]    @relation("TimesheetApprovals")
  timesheetSubmissions     TimesheetSubmission[]
  punchTimesheets          Timesheet[]
  timeChangeRequests       TimeChangeRequest[]      @relation("TimeChangeRequests")
  approvedTimeChanges      TimeChangeRequest[]      @relation("TimeChangeApprovals")
  rejectedTimeChanges      TimeChangeRequest[]      @relation("TimeChangeRejections")
  fileRecords              FileRecord[]             @relation("FileRecords")
  quoteRevisions           QuoteRevision[]          @relation("QuoteRevisionCreator")
  timeOffRequests          TimeOffRequest[]         @relation("TimeOffRequests")
  approvedTimeOff          TimeOffRequest[]         @relation("TimeOffApprovals")
  rejectedTimeOff          TimeOffRequest[]         @relation("TimeOffRejections")
  expenseReports           ExpenseReport[]          @relation("ExpenseReports")
  approvedExpenses         ExpenseReport[]          @relation("ExpenseApprovals")
  rejectedExpenses         ExpenseReport[]          @relation("ExpenseRejections")
  serviceReports           ServiceReport[]          @relation("ServiceReports")
  deliverableAssignments   JobDeliverable[]         @relation("DeliverableAssignments")
  createdBillingMilestones BillingMilestone[]       @relation("BillingMilestoneCreator")
  assignedQuotes           Quote[]                  @relation("QuoteAssignedTo")
  assignedTasks            TaskCard[]               @relation("TaskAssignee")

  @@map("users")
}

model Job {
  id                 String                   @id @default(cuid())
  jobNumber          String                   @unique
  title              String
  description        String?
  type               String                   @default("JOB")
  status             String                   @default("ACTIVE") // Using String for now, will migrate to JobStatus enum later
  createdFromQuoteId String? // Link to the quote that created this job
  priority           String                   @default("MEDIUM")
  startDate          DateTime?
  endDate            DateTime?
  estimatedHours     Float?
  actualHours        Float?
  assignedToId       String?
  createdById        String
  customerId         String?
  workCode           String?
  estimatedCost      Float?
  dueTodayPercent    Float?
  inQuickBooks       Boolean                  @default(false)
  inLDrive           Boolean                  @default(false)
  fileLink           String?
  quoteId            String?                  @unique
  relatedQuoteId     String?
  convertedAt        DateTime?
  lockedHours        Float?
  currentRevision    String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  lastFollowUp       DateTime?
  ecoOrders          EngineeringChangeOrder[]
  quotedLabor        JobLaborEstimate[]
  quote              Quote?                   @relation(fields: [quoteId], references: [id])
  customer           Customer?                @relation(fields: [customerId], references: [id])
  createdBy          User                     @relation("JobCreator", fields: [createdById], references: [id])
  assignedTo         User?                    @relation("JobAssignee", fields: [assignedToId], references: [id])
  timeEntries        TimeEntry[]
  fileRecords        FileRecord[]             @relation("JobFiles")
  milestones         JobMilestone[]           @relation("JobMilestones")
  expenseReports     ExpenseReport[]          @relation("JobExpenses")
  serviceReports     ServiceReport[]          @relation("JobServiceReports")
  purchaseOrders     PurchaseOrder[]          @relation("JobPurchaseOrders")
  deliverables       JobDeliverable[]         @relation("JobDeliverables")
  billingMilestones  BillingMilestone[]       @relation("JobBillingMilestones")
  tasks              TaskCard[]               @relation("JobTasks")

  @@map("jobs")
}

model Customer {
  id        String    @id @default(cuid())
  name      String    @unique
  email     String?
  phone     String?
  address   String?
  isActive  Boolean   @default(true)
  fileLink  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  contacts  Contact[]
  jobs      Job[]
  quotes    Quote[]

  @@map("customers")
}

model TimeEntry {
  id            String               @id @default(cuid())
  date          DateTime
  regularHours  Float                @default(0)
  overtimeHours Float                @default(0)
  notes         String?
  billable      Boolean              @default(true)
  rate          Decimal?
  userId        String?
  jobId         String
  laborCodeId   String?
  submissionId  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  submission    TimesheetSubmission? @relation(fields: [submissionId], references: [id])
  laborCode     LaborCode?           @relation(fields: [laborCodeId], references: [id])
  job           Job                  @relation(fields: [jobId], references: [id])
  user          User?                @relation(fields: [userId], references: [id])

  @@map("time_entries")
}

model TimesheetSubmission {
  id              String      @id @default(cuid())
  userId          String
  weekStart       DateTime
  weekEnd         DateTime
  type            String      @default("TIME") // "ATTENDANCE" or "TIME"
  status          String      @default("DRAFT")
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  timeEntries     TimeEntry[]
  rejectedBy      User?       @relation("TimesheetRejections", fields: [rejectedById], references: [id])
  approvedBy      User?       @relation("TimesheetApprovals", fields: [approvedById], references: [id])
  user            User        @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart, type], name: "userId_weekStart_type_key")
  @@index([userId, weekStart], name: "userId_weekStart_idx")
  @@map("timesheet_submissions")
}

model LaborCode {
  id             String               @id @default(cuid())
  code           String               @unique
  name           String
  description    String?
  category       String
  hourlyRate     Decimal              @default(0)
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  jobEstimates   JobLaborEstimate[]
  quoteEstimates QuoteLaborEstimate[]
  timeEntries    TimeEntry[]

  @@map("labor_codes")
}

model Quote {
  id                   String               @id @default(cuid())
  quoteNumber          String               @unique
  title                String
  description          String?
  customerId           String?
  assignedToId         String?
  amount               Float                @default(0)
  validUntil           DateTime?
  status               QuoteStatus          @default(DRAFT)
  quoteType            String               @default("PROJECT") // PROJECT, PART_SALE
  isActive             Boolean              @default(true)
  paymentTerms         String?
  estimatedHours       Float?
  hourlyRate           Float?
  laborCost            Float?
  materialCost         Float?
  overheadCost         Float?
  profitMargin         Float?
  customerContactName  String?
  customerContactEmail String?
  customerContactPhone String?
  lastFollowUp         DateTime?
  quoteFile            String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  linkedBOMs           BOM[]                @relation("QuoteToBOM")
  job                  Job?
  customer             Customer?            @relation(fields: [customerId], references: [id])
  assignedTo           User?                @relation("QuoteAssignedTo", fields: [assignedToId], references: [id])
  fileRecords          FileRecord[]         @relation("QuoteFiles")
  revisions            QuoteRevision[]      @relation("QuoteRevisions")
  lostReason           QuoteLostReason?
  laborEstimates       QuoteLaborEstimate[]
  milestones           QuoteMilestone[]
  tasks                TaskCard[]           @relation("QuoteTasks")

  @@map("quotes")
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  email      String?
  phone      String?
  position   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

model JobLaborEstimate {
  id             String    @id @default(cuid())
  jobId          String
  laborCodeId    String
  estimatedHours Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  laborCode      LaborCode @relation(fields: [laborCodeId], references: [id])
  job            Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, laborCodeId])
  @@map("job_labor_estimates")
}

model PartsService {
  id           String    @id @default(cuid())
  jobNumber    String    @unique
  createdBy    String?
  customerName String?
  custContact  String?
  description  String?
  vendor       String?
  startDate    DateTime?
  dueDate      DateTime?
  jobStatus    String?
  inQuickBooks Boolean   @default(false)
  inLDrive     Boolean   @default(false)
  quoteNumber  String?
  invoiced     String?
  dateInvoiced DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("parts_services")
}

model EngineeringChangeOrder {
  id              String    @id @default(cuid())
  ecoNumber       String    @unique
  jobId           String
  oldHours        Float
  newHours        Float
  oldCost         Float?
  newCost         Float?
  reasonForChange String?
  laborChanges    String?
  submittedById   String
  submittedAt     DateTime  @default(now())
  appliedAt       DateTime?
  status          String    @default("PENDING")
  revision        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  submittedBy     User      @relation(fields: [submittedById], references: [id])
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("engineering_change_orders")
}

model Part {
  id                 String              @id @default(cuid())
  partNumber         String              @unique
  manufacturer       String
  description        String?
  category           String?
  subcategory        String?
  primarySource      String?
  secondarySources   String?
  purchasePrice      Float?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bomParts           BOMPart[]
  packageParts       PackagePart[]
  relatedPartsB      PartRelation[]      @relation("PartB")
  relatedPartsA      PartRelation[]      @relation("PartA")
  vendorPrices       VendorPartPrice[]
  purchaseOrderItems PurchaseOrderItem[]

  @@map("parts")
}

model PackagePart {
  id        String   @id @default(cuid())
  packageId String
  partId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  part      Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, partId])
  @@map("package_parts")
}

model PartRelation {
  id        String   @id @default(cuid())
  partAId   String
  partBId   String
  createdAt DateTime @default(now())
  partB     Part     @relation("PartB", fields: [partBId], references: [id], onDelete: Cascade)
  partA     Part     @relation("PartA", fields: [partAId], references: [id], onDelete: Cascade)

  @@unique([partAId, partBId])
  @@map("part_relations")
}

model Package {
  id          String        @id @default(cuid())
  name        String
  type        String        @default("Package")
  description String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  parts       PackagePart[]

  @@map("packages")
}

model BOM {
  id            String    @id @default(cuid())
  name          String
  status        BOMStatus @default(DRAFT)
  notes         String?
  tags          String?
  linkedQuoteId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  parts         BOMPart[]
  linkedQuote   Quote?    @relation("QuoteToBOM", fields: [linkedQuoteId], references: [id])

  @@map("boms")
}

model BOMPart {
  id                String        @id @default(cuid())
  bomId             String
  partId            String?
  quantity          Int           @default(1)
  purchasePrice     Float
  markupPercent     Float         @default(20.0)
  customerPrice     Float
  manufacturer      String
  description       String?
  source            String?
  notes             String?
  estimatedDelivery DateTime?
  status            BOMPartStatus @default(HOLD)
  partNumber        String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  originalPart      Part?         @relation(fields: [partId], references: [id])
  bom               BOM           @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@map("bom_parts")
}

enum BOMPartStatus {
  HOLD
  ORDER
  PLACED
  HERE
  STOCK
  CUSTOMER_SUPPLIED
}

enum BOMStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum QuoteStatus {
  DRAFT
  APPROVED
  CANCELLED
  SENT
  WON
  LOST
}

enum JobStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Timesheet {
  id                     String              @id @default(cuid())
  userId                 String
  date                   DateTime
  clockInTime            DateTime
  clockOutTime           DateTime?
  totalHours             Float?
  status                 String              @default("in-progress") // in-progress, completed, needs-review
  // Geolocation fields
  geoLat                 Float? // Latitude for clock-in
  geoLon                 Float? // Longitude for clock-in
  geoAccuracy            Float? // Accuracy in meters
  locationDenied         Boolean             @default(false) // True if user denied location permission
  // Geolocation for clock-out
  clockOutGeoLat         Float? // Latitude for clock-out
  clockOutGeoLon         Float? // Longitude for clock-out
  clockOutGeoAccuracy    Float? // Accuracy for clock-out
  clockOutLocationDenied Boolean             @default(false) // True if location denied on clock-out
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobEntries             JobEntry[]
  changeRequests         TimeChangeRequest[]

  @@map("timesheets")
}

model TimeChangeRequest {
  id                    String     @id @default(cuid())
  timesheetId           String?
  userId                String
  date                  DateTime
  originalClockInTime   DateTime
  originalClockOutTime  DateTime?
  requestedClockInTime  DateTime
  requestedClockOutTime DateTime?
  reason                String
  status                String     @default("PENDING") // PENDING, APPROVED, REJECTED
  submittedAt           DateTime   @default(now())
  approvedAt            DateTime?
  approvedById          String?
  rejectedAt            DateTime?
  rejectedById          String?
  rejectionReason       String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  timesheet             Timesheet? @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  user                  User       @relation("TimeChangeRequests", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy            User?      @relation("TimeChangeApprovals", fields: [approvedById], references: [id])
  rejectedBy            User?      @relation("TimeChangeRejections", fields: [rejectedById], references: [id])

  @@map("time_change_requests")
}

model JobEntry {
  id           String    @id @default(cuid())
  timesheetId  String
  jobNumber    String
  laborCode    String
  punchInTime  DateTime
  punchOutTime DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  timesheet    Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@map("job_entries")
}

model FileRecord {
  id                     String                @id @default(cuid())
  storagePath            String // Path in storage (e.g., 'quotes/quote-Q0001.pdf')
  fileUrl                String? // Public URL or signed URL
  fileName               String // Original filename
  fileType               String // MIME type (e.g., 'application/pdf')
  fileSize               Int? // File size in bytes
  metadata               Json? // Additional metadata (JSON)
  createdById            String
  linkedJobId            String?
  linkedQuoteId          String?
  linkedServiceReportId  String?
  linkedEquipmentId      String?
  linkedDeliverableId    String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  createdBy              User                  @relation("FileRecords", fields: [createdById], references: [id])
  linkedJob              Job?                  @relation("JobFiles", fields: [linkedJobId], references: [id], onDelete: SetNull)
  linkedQuote            Quote?                @relation("QuoteFiles", fields: [linkedQuoteId], references: [id], onDelete: SetNull)
  linkedServiceReport    ServiceReport?        @relation("ServiceReportAttachments", fields: [linkedServiceReportId], references: [id], onDelete: SetNull)
  expenseReceipt         ExpenseReport?        @relation("ExpenseReceipts")
  linkedEquipment        Equipment?            @relation("EquipmentManuals", fields: [linkedEquipmentId], references: [id], onDelete: SetNull)
  calibrationCertificate EquipmentCalibration? @relation("CalibrationCertificates")
  deliverableFiles       JobDeliverable?       @relation("DeliverableFiles", fields: [linkedDeliverableId], references: [id], onDelete: SetNull)

  @@index([linkedJobId])
  @@index([linkedQuoteId])
  @@index([linkedServiceReportId])
  @@index([linkedEquipmentId])
  @@index([linkedDeliverableId])
  @@index([createdById])
  @@index([fileType])
  @@map("file_records")
}

model QuoteRevision {
  id             String   @id @default(cuid())
  quoteId        String
  revisionNumber Int
  data           Json // Snapshot of quote data at this revision
  createdById    String
  createdAt      DateTime @default(now())
  quote          Quote    @relation("QuoteRevisions", fields: [quoteId], references: [id], onDelete: Cascade)
  createdBy      User     @relation("QuoteRevisionCreator", fields: [createdById], references: [id])

  @@unique([quoteId, revisionNumber])
  @@index([quoteId])
  @@index([createdById])
  @@map("quote_revisions")
}

model JobMilestone {
  id                 String             @id @default(cuid())
  jobId              String
  name               String
  description        String?
  milestoneType      String // ENGINEERING, PANEL_BUILD, FAT, SAT, COMMISSIONING, OTHER
  scheduledStartDate DateTime?
  scheduledEndDate   DateTime?
  actualStartDate    DateTime?
  actualEndDate      DateTime?
  status             String             @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED, BLOCKED
  billingPercentage  Float? // Percentage of total job value
  isBillingTrigger   Boolean            @default(false) // Triggers invoice when completed
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  job                Job                @relation("JobMilestones", fields: [jobId], references: [id], onDelete: Cascade)
  billingMilestones  BillingMilestone[] @relation("BillingMilestoneLink")

  @@index([jobId])
  @@index([status])
  @@index([milestoneType])
  @@map("job_milestones")
}

model JobDeliverable {
  id              String       @id @default(cuid())
  jobId           String
  templateCode    String? // RSA PM010-PM140 template codes
  name            String
  description     String?
  deliverableType String       @default("DOCUMENT") // DOCUMENT, HARDWARE, SOFTWARE, OTHER
  status          String       @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, DELIVERED, ACCEPTED, REJECTED
  assignedToId    String?
  dueDate         DateTime?
  completedDate   DateTime?
  deliveredDate   DateTime?
  acceptedDate    DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  job             Job          @relation("JobDeliverables", fields: [jobId], references: [id], onDelete: Cascade)
  assignedTo      User?        @relation("DeliverableAssignments", fields: [assignedToId], references: [id], onDelete: SetNull)
  files           FileRecord[] @relation("DeliverableFiles")

  @@index([jobId])
  @@index([status])
  @@index([assignedToId])
  @@index([templateCode])
  @@map("job_deliverables")
}

model BillingMilestone {
  id            String        @id @default(cuid())
  jobId         String
  milestoneId   String? // Optional link to JobMilestone
  invoiceNumber String?
  amount        Float
  percentage    Float // Percentage of total job value
  status        String        @default("PENDING") // PENDING, INVOICED, PAID, CANCELLED
  invoicedAt    DateTime?
  paidAt        DateTime?
  dueDate       DateTime?
  notes         String?
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  job           Job           @relation("JobBillingMilestones", fields: [jobId], references: [id], onDelete: Cascade)
  milestone     JobMilestone? @relation("BillingMilestoneLink", fields: [milestoneId], references: [id], onDelete: SetNull)
  createdBy     User          @relation("BillingMilestoneCreator", fields: [createdById], references: [id])

  @@index([jobId])
  @@index([milestoneId])
  @@index([status])
  @@index([invoicedAt])
  @@map("billing_milestones")
}

model TimeOffRequest {
  id              String    @id @default(cuid())
  userId          String
  startDate       DateTime
  endDate         DateTime
  requestType     String // VACATION, SICK, PERSONAL, UNPAID, OTHER
  reason          String?
  hours           Float?
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  submittedAt     DateTime  @default(now())
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation("TimeOffRequests", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy      User?     @relation("TimeOffApprovals", fields: [approvedById], references: [id])
  rejectedBy      User?     @relation("TimeOffRejections", fields: [rejectedById], references: [id])

  @@index([userId])
  @@index([status])
  @@index([requestType])
  @@index([startDate])
  @@map("time_off_requests")
}

model ExpenseReport {
  id              String      @id @default(cuid())
  userId          String
  reportDate      DateTime
  description     String
  amount          Float
  category        String // TRAVEL, MEALS, SUPPLIES, EQUIPMENT, OTHER
  jobId           String?
  receiptFileId   String?     @unique
  status          String      @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, PAID
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation("ExpenseReports", fields: [userId], references: [id], onDelete: Cascade)
  job             Job?        @relation("JobExpenses", fields: [jobId], references: [id], onDelete: SetNull)
  receiptFile     FileRecord? @relation("ExpenseReceipts", fields: [receiptFileId], references: [id], onDelete: SetNull)
  approvedBy      User?       @relation("ExpenseApprovals", fields: [approvedById], references: [id])
  rejectedBy      User?       @relation("ExpenseRejections", fields: [rejectedById], references: [id])

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([jobId])
  @@index([reportDate])
  @@map("expense_reports")
}

model ServiceReport {
  id            String       @id @default(cuid())
  jobId         String
  userId        String
  reportDate    DateTime
  serviceType   String // INSTALLATION, MAINTENANCE, REPAIR, COMMISSIONING, TRAINING, OTHER
  description   String
  hoursWorked   Float?
  customerNotes String?
  internalNotes String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  job           Job          @relation("JobServiceReports", fields: [jobId], references: [id], onDelete: Cascade)
  user          User         @relation("ServiceReports", fields: [userId], references: [id], onDelete: Cascade)
  attachments   FileRecord[] @relation("ServiceReportAttachments")

  @@index([jobId])
  @@index([userId])
  @@index([reportDate])
  @@index([serviceType])
  @@map("service_reports")
}

model Vendor {
  id             String            @id @default(cuid())
  name           String            @unique
  contactName    String?
  email          String?
  phone          String?
  address        String?
  website        String?
  category       String? // ELECTRONICS, MECHANICAL, SOFTWARE, SUPPLIES, SERVICES, OTHER
  notes          String?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  partPrices     VendorPartPrice[]
  purchaseOrders PurchaseOrder[]

  @@index([name])
  @@index([category])
  @@index([isActive])
  @@map("vendors")
}

model VendorPartPrice {
  id                   String   @id @default(cuid())
  vendorId             String
  partId               String
  price                Float
  leadTimeDays         Int?
  effectiveDate        DateTime @default(now())
  minimumOrderQuantity Int?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  vendor               Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  part                 Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([vendorId, partId, effectiveDate])
  @@index([vendorId])
  @@index([partId])
  @@index([effectiveDate])
  @@map("vendor_part_prices")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique
  vendorId     String
  jobId        String?
  status       String              @default("DRAFT") // DRAFT, SENT, RECEIVED, PARTIALLY_RECEIVED, COMPLETED, CANCELLED
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  totalAmount  Float?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  vendor       Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  job          Job?                @relation("JobPurchaseOrders", fields: [jobId], references: [id], onDelete: SetNull)
  items        PurchaseOrderItem[]

  @@index([vendorId])
  @@index([jobId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  partId           String?
  description      String
  quantity         Int
  unitPrice        Float
  totalPrice       Float
  receivedQuantity Int           @default(0)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  part             Part?         @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([partId])
  @@map("purchase_order_items")
}

model Equipment {
  id                 String                    @id @default(cuid())
  name               String
  type               String // CNC, WELDER, MILL, LATHE, FORKLIFT, CALIBRATION_TOOL, OTHER
  serial             String?
  purchaseDate       DateTime?
  serviceStatus      String                    @default("OPERATIONAL") // OPERATIONAL, MAINTENANCE, REPAIR, OUT_OF_SERVICE
  pmSchedule         String? // Preventive maintenance schedule (e.g., "Every 3 months")
  lastPMService      DateTime?
  nextPMService      DateTime?
  assignedArea       String? // Location/area where equipment is assigned
  notes              String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  maintenanceLogs    EquipmentMaintenanceLog[]
  calibrationHistory EquipmentCalibration[]
  manuals            FileRecord[]              @relation("EquipmentManuals")

  @@index([type])
  @@index([serviceStatus])
  @@index([assignedArea])
  @@map("equipment")
}

model EquipmentMaintenanceLog {
  id          String    @id @default(cuid())
  equipmentId String
  serviceDate DateTime
  serviceType String // PREVENTIVE, REPAIR, INSPECTION, CALIBRATION
  description String
  performedBy String? // User name or service provider
  cost        Float?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([serviceDate])
  @@index([serviceType])
  @@map("equipment_maintenance_logs")
}

model EquipmentCalibration {
  id                  String      @id @default(cuid())
  equipmentId         String
  calibrationDate     DateTime
  nextCalibrationDate DateTime?
  calibratedBy        String? // User name or service provider
  certificateNumber   String?
  certificateFileId   String?     @unique
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  equipment           Equipment   @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  certificateFile     FileRecord? @relation("CalibrationCertificates", fields: [certificateFileId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
  @@index([calibrationDate])
  @@index([nextCalibrationDate])
  @@map("equipment_calibrations")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String // CREATE, UPDATE, DELETE, APPROVE, REJECT, SUBMIT
  resourceType String // USER, TIME_OFF_REQUEST, EXPENSE_REPORT, TIME_CHANGE_REQUEST, etc.
  resourceId   String?
  details      Json? // Additional details about the action
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation("AuditLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceType])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model QuoteLostReason {
  id        String   @id @default(cuid())
  quoteId   String   @unique
  reason    String // PRICE, TIMELINE, SPECIFICATIONS, COMPETITOR, OTHER
  details   String?
  createdAt DateTime @default(now())
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([reason])
  @@map("quote_lost_reasons")
}

model QuoteLaborEstimate {
  id             String    @id @default(cuid())
  quoteId        String
  laborCodeId    String
  estimatedHours Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  laborCode      LaborCode @relation(fields: [laborCodeId], references: [id])
  quote          Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, laborCodeId])
  @@map("quote_labor_estimates")
}

model QuoteMilestone {
  id                 String    @id @default(cuid())
  quoteId            String
  name               String
  description        String?
  milestoneType      String // ENGINEERING, PANEL_BUILD, FAT, SAT, COMMISSIONING, OTHER
  scheduledStartDate DateTime?
  scheduledEndDate   DateTime?
  actualStartDate    DateTime?
  actualEndDate      DateTime?
  status             String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED, BLOCKED
  billingPercentage  Float? // Percentage of total quote value
  isBillingTrigger   Boolean   @default(false) // Triggers invoice when completed
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  quote              Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([status])
  @@index([milestoneType])
  @@map("quote_milestones")
}

model TaskCard {
  id                  String    @id @default(cuid())
  jobId               String?
  quoteId             String?
  name                String
  description         String?
  assignedToId        String?
  dueDate             DateTime?
  status              String    @default("BACKLOG") // BACKLOG, IN_PROGRESS, WAITING, COMPLETED
  position            Int       @default(0) // For ordering within column
  taskCode            String? // PM, SV, or AD task code (e.g., PM010-0100)
  taskCodeDescription String? // Description of the task code
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  job        Job?   @relation("JobTasks", fields: [jobId], references: [id], onDelete: Cascade)
  quote      Quote? @relation("QuoteTasks", fields: [quoteId], references: [id], onDelete: Cascade)
  assignedTo User?  @relation("TaskAssignee", fields: [assignedToId], references: [id])

  @@index([jobId])
  @@index([quoteId])
  @@index([status])
  @@index([taskCode])
  @@map("task_cards")
}

model TaskCode {
  id          String    @id @default(cuid())
  code        String    @unique
  description String
  category    String    // PM, SV, or AD
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([code])
  @@map("task_codes")
}

// eBay Automation Models
model EbayListing {
  id                    String    @id @default(cuid())
  code                  String    @unique
  title                 String?
  description           String?
  listingStatus         String    @default("draft") // draft, active_listing, active, sold, ended
  userId                String
  categoryId            String?
  storageLocationId     String?
  conditionId           String?
  conditionText         String?
  testStatusId          String?
  testStatus            String? // Legacy support
  notes                 String?
  needsInspection       Boolean   @default(false)
  needsTesting          Boolean   @default(false)
  postedDate            DateTime?
  suggestedPrice        Float?
  suggestedAuctionPrice Float?
  suggestedShipping     Float?
  imageFolderPath       String?
  ebayDraftData         String? // JSON string for draft listing data
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  images             EbayListingImage[]
  category           EbayCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  storageLocation    EbayStorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  condition          EbayCondition?       @relation(fields: [conditionId], references: [id], onDelete: SetNull)
  testStatusRelation EbayTestStatus?      @relation(fields: [testStatusId], references: [id], onDelete: SetNull)
  aiAnalysis         EbayAIAnalysis?
  ebayData           EbayData?
  alerts             EbayAlert[]

  @@index([userId])
  @@index([categoryId])
  @@index([storageLocationId])
  @@index([listingStatus])
  @@index([createdAt])
  @@map("ebay_listings")
}

model EbayListingImage {
  id        String      @id @default(cuid())
  listingId String
  filename  String
  url       String
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  listing   EbayListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([order])
  @@map("ebay_listing_images")
}

model EbayAIAnalysis {
  id                String      @id @default(cuid())
  listingId         String      @unique
  autoTitle         String?
  autoDescription   String?
  autoCategory      String?
  detectedBrand     String?
  detectedModel     String?
  itemSpecifics     String? // JSON string
  suggestedCategory String?
  confidenceScore   Float?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  listing           EbayListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("ebay_ai_analyses")
}

model EbayCategory {
  id        String        @id @default(cuid())
  name      String        @unique
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  listings  EbayListing[]

  @@map("ebay_categories")
}

model EbayStorageLocation {
  id        String        @id @default(cuid())
  name      String        @unique
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  listings  EbayListing[]

  @@map("ebay_storage_locations")
}

model EbayCondition {
  id        String        @id @default(cuid())
  name      String        @unique
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  listings  EbayListing[]

  @@map("ebay_conditions")
}

model EbayAlert {
  id        String      @id @default(cuid())
  listingId String
  type      String // aging, inspection, testing, pricing, etc.
  message   String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  listing   EbayListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([isActive])
  @@map("ebay_alerts")
}

model EbayData {
  id             String      @id @default(cuid())
  listingId      String      @unique
  ebayItemId     String?
  ebayListingUrl String?
  status         String? // draft_stub, pending, uploaded, failed
  itemSpecifics  String? // JSON string
  uploadedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  listing        EbayListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("ebay_data")
}

model EbayTestStatus {
  id        String        @id @default(cuid())
  name      String        @unique
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  listings  EbayListing[]

  @@map("ebay_test_statuses")
}
