# Sandbox/Development Environment Variables Template
# Copy this file to .env.sandbox and update with your actual values
# DO NOT commit .env.sandbox to git

# Database - PostgreSQL (separate database for sandbox)
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://afp:CHANGE_THIS_PASSWORD@localhost:5432/automation_firm_db_sandbox"

# NextAuth Configuration
# Use a different port or subdomain for sandbox
NEXTAUTH_URL="https://sandbox.your-domain.com"
# Or if using IP: NEXTAUTH_URL="https://YOUR_SERVER_IP:3001"
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_DIFFERENT_SECURE_RANDOM_STRING_MIN_32_CHARS"

# Email Configuration (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# File Upload
UPLOAD_DIR="./uploads-sandbox"
MAX_FILE_SIZE="10485760" # 10MB

# External Integrations (for future use)
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""

# Microsoft 365 Authentication (Azure AD)
# Can use same Azure AD app or separate one for sandbox
MICROSOFT_CLIENT_ID="your-azure-ad-app-client-id"
MICROSOFT_CLIENT_SECRET="your-azure-ad-app-client-secret"
MICROSOFT_TENANT_ID="your-tenant-id"

# AI Services (optional)
OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""

# Node Environment
NODE_ENV="production"
PORT="3001"

