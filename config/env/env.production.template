# Production Environment Variables Template
# Copy this file to .env.production and update with your actual values
# DO NOT commit .env.production to git

# Database - PostgreSQL
# Format: postgresql://username:password@host:port/database
# For Docker: postgresql://afp:YOUR_PASSWORD@localhost:5432/automation_firm_db
# For native PostgreSQL: postgresql://username:password@localhost:5432/automation_firm_db
DATABASE_URL="postgresql://afp:CHANGE_THIS_PASSWORD@localhost:5432/automation_firm_db"

# NextAuth Configuration
# Update with your production domain
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS"

# Email Configuration (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760" # 10MB

# External Integrations (for future use)
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""

# Microsoft 365 Authentication (Azure AD)
# Update these with your production Azure AD app credentials
MICROSOFT_CLIENT_ID="your-azure-ad-app-client-id"
MICROSOFT_CLIENT_SECRET="your-azure-ad-app-client-secret"
MICROSOFT_TENANT_ID="your-tenant-id"

# AI Services (optional)
OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""

# Node Environment
NODE_ENV="production"

