# Database
DATABASE_URL="postgresql://username:password@localhost:5432/automation_firm_db"

# NextAuth
NEXTAUTH_URL="https://192.168.10.95:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Email (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760" # 10MB

# External Integrations (for future use)
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""

# Microsoft 365 Authentication (Azure AD)
MICROSOFT_CLIENT_ID="your-azure-ad-app-client-id"
MICROSOFT_CLIENT_SECRET="your-azure-ad-app-client-secret"
MICROSOFT_TENANT_ID="your-tenant-id"

# AI Services
OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""

# Storage Configuration
# Options: 'local' or 's3' (default: 'local')
STORAGE_ADAPTER="local"
STORAGE_BASE_PATH="./storage"

# S3 Storage (DigitalOcean Spaces / AWS S3)
# Required when STORAGE_ADAPTER=s3
S3_ENDPOINT=""
S3_KEY=""
S3_SECRET=""
S3_BUCKET=""
S3_REGION="us-east-1"
S3_PUBLIC_URL=""


