# Database
DATABASE_URL="file:./prisma/dev.db"

# Server
PORT=5000
NODE_ENV=development
BACKEND_URL=http://192.168.10.70:5000

# OpenAI AI Integration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
ENABLE_REAL_AI=false
# Daily limits to prevent runaway costs
AI_DAILY_TOKEN_LIMIT=100000
AI_DAILY_COST_LIMIT=5.00
AI_MAX_CONCURRENT=1

# eBay API Integration (Production Only)
# Get credentials from https://developer.ebay.com/`n# Just add your App ID and Cert ID - that's all you need!

EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here
EBAY_REDIRECT_URI=http://192.168.10.70:5000/api/ebay/callback

# eBay Policy IDs (optional - get from your eBay account)
# These are required for creating listings but can be set up later
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=

# File Upload
MAX_FILE_SIZE=10485760

