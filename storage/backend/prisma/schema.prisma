// This file is generated by Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  metadata     String? // JSON string for storing additional data like eBay tokens
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  listings Listing[]

  @@map("users")
}

model Listing {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  userId          Int?      @map("user_id") // Optional - single user system
  title           String?
  location        String?   // Text or dropdown value
  conditionText   String?   @map("condition_text") // "New", "Like New", "Used", "For Parts"
  testStatus      String?   @map("test_status") // "Needs Testing", "Tested Working", "Needs Repair"
  notes           String?   // Optional notes
  imageFolderPath String?   @map("image_folder_path") // Path to /listings/{listingId}/images/
  listingStatus   String    @default("draft") @map("listing_status") // "draft", "ready_to_upload", "active_listing", "sold", "archived"
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Legacy fields (kept for backward compatibility, can be removed later)
  description           String?
  storageLocationId     Int?      @map("storage_location_id")
  conditionId           Int?      @map("condition_id")
  categoryId            Int?      @map("category_id")
  currentPrice          Float?    @map("current_price")
  suggestedPrice        Float?    @map("suggested_price")
  suggestedAuctionPrice Float?    @map("suggested_auction_price")
  suggestedShipping     Float?    @map("suggested_shipping")
  status                String    @default("draft")
  postedDate            DateTime? @map("posted_date")
  daysSincePosted       Int?      @map("days_since_posted")
  needsInspection       Boolean   @default(false) @map("needs_inspection")
  needsTesting          Boolean   @default(false) @map("needs_testing")
  metadata              String?

  user            User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id])
  condition       Condition?       @relation(fields: [conditionId], references: [id])
  category        Category?        @relation(fields: [categoryId], references: [id])

  images       ListingImage[]
  priceHistory PriceHistory[]
  ebayData     EbayData?
  aiAnalysis   AIAnalysis?
  alerts       Alert[]

  @@map("listings")
}

model ListingImage {
  id        Int      @id @default(autoincrement())
  listingId Int      @map("listing_id")
  filename  String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

model PriceHistory {
  id           Int      @id @default(autoincrement())
  listingId    Int      @map("listing_id")
  price        Float
  changeReason String?  @map("change_reason")
  createdAt    DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("price_history")
}

model EbayData {
  id            Int       @id @default(autoincrement())
  listingId     Int       @unique @map("listing_id")
  ebayListingId String?   @unique @map("ebay_listing_id")
  listingUrl    String?   @map("listing_url")
  status        String?
  itemSpecifics String?   @map("item_specifics")
  listedAt      DateTime? @map("listed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("ebay_data")
}

model AIAnalysis {
  id                Int      @id @default(autoincrement())
  listingId         Int      @unique @map("listing_id")
  detectedBrand     String?  @map("detected_brand")
  detectedModel     String?  @map("detected_model")
  autoDescription   String?  @map("auto_description")
  itemSpecifics     String?  @map("item_specifics")
  suggestedCategory String?  @map("suggested_category")
  confidenceScore   Float?   @map("confidence_score")
  analyzedAt        DateTime @default(now()) @map("analyzed_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("ai_analysis")
}

model Alert {
  id              Int      @id @default(autoincrement())
  listingId       Int      @map("listing_id")
  type            String
  severity        String
  message         String
  suggestedAction String?  @map("suggested_action")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model StorageLocation {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  listings Listing[]

  @@map("storage_locations")
}

model Condition {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  multiplier  Float    @default(1.0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  listings Listing[]

  @@map("conditions")
}

model Category {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  parentId  Int?     @map("parent_id")
  ebayId    String?  @map("ebay_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  listings Listing[]

  @@map("categories")
}

model AICostTracking {
  id            Int      @id @default(autoincrement())
  operationType String   @map("operation_type") // 'analyze' or 'description'
  tokensUsed    Int      @map("tokens_used")
  costUSD       Float    @map("cost_usd")
  listingId     Int?     @map("listing_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("ai_cost_tracking")
}

model AISettings {
  id                    Int      @id @default(autoincrement())
  dailyTokenLimit       Int      @default(100000) @map("daily_token_limit")
  dailyCostLimit        Float    @default(5.00) @map("daily_cost_limit")
  maxConcurrentOperations Int   @default(1) @map("max_concurrent_operations")
  currentDailyTokens    Int      @default(0) @map("current_daily_tokens")
  currentDailyCost      Float    @default(0.0) @map("current_daily_cost")
  lastResetDate         DateTime @default(now()) @map("last_reset_date")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("ai_settings")
}
